# Copy to /opt/mise/.env, chmod 600, owner mise.
# Generate the secret:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MISE_SECRET_KEY=CHANGE_ME
MISE_ADMIN_PASSWORD=CHANGE_ME
MISE_BASE_URL=http://flow:8400
MISE_SITE_NAME=Kevin Lee Photography
# Set true once serving via HTTPS through the tunnel:
MISE_COOKIE_SECURE=false
# Public marketing (optional)
# MISE_INSTAGRAM_URL=https://www.instagram.com/your-handle/
MISE_PLAUSIBLE_DOMAIN=kleephotography.com
# Sample gallery for prospects — slug auto-detected if unset (title/slug contains "sample")
# MISE_DEMO_GALLERY_SLUG=sample-tasting-menu
# MISE_DEMO_GALLERY_PIN=1234

# ── Integrations (all optional; each feature stays dormant until its keys are set) ──
# Stripe Checkout + webhook (invoice pay page). Webhook secret from the CLI/dashboard.
# MISE_STRIPE_SECRET_KEY=sk_live_xxx
# MISE_STRIPE_WEBHOOK_SECRET=whsec_xxx
# Gmail SMTP for manual document sends (use a Google app password, not your login).
# MISE_GMAIL_USER=you@gmail.com
# MISE_GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Notion one-way status sync (invoice sent/paid → Session page).
# MISE_NOTION_TOKEN=ntn_xxx
# MISE_NOTION_SESSIONS_DB=
# MISE_NOTION_BOOKINGS_DB=
# API version (default 2022-06-28). Set to 2025-09-03 ONLY after validating on staging;
# that version requires the *_DS data-source ids below for page creation. See
# docs/NOTION-MODERNIZATION.md.
# MISE_NOTION_VERSION=2022-06-28
# Data-source ids (only needed when MISE_NOTION_VERSION=2025-09-03+). From Notion:
# database settings → Manage data sources → Copy data source ID.
# MISE_NOTION_SESSIONS_DS=
# MISE_NOTION_BOOKINGS_DS=
# Google Calendar OAuth (scheduling availability). Calendar id defaults to "primary".
# MISE_GOOGLE_CLIENT_ID=
# MISE_GOOGLE_CLIENT_SECRET=
# MISE_GOOGLE_CALENDAR_ID=primary
# Odysseus caption AI hand-off (admin "draft caption" button).
# MISE_ODYSSEUS_CAPTION_URL=
# MISE_ODYSSEUS_CAPTION_TOKEN=
# Phase 1 strangler flag: route caption drafting through the app/providers facade and
# record provenance to the ai_runs ledger. Default off = legacy caption_ai path.
# MISE_PROVIDER_FACADE_CONTENT=false
# AI-assisted culling: arms the keep/cut deck AND the client-delivery gate (one switch). When
# on, a cut frame is hidden from clients (reversible, audited; never deleted). Off = inert,
# delivery unchanged. Ranks on the keeper score Vision writes (see MISE_ARGUS_*). Runbook §2.
# MISE_CULL_UI=false
# Local keeper-scorer: with this on AND MISE_VISION_CHALLENGER_URL set, the cull deck's
# "Re-score with local AI" button scores a gallery's photos per-asset on your local Qwen3-VL
# endpoint (writes argus_keeper_score only). Independent of the Argus->Qwen production cutover.
# MISE_CULL_SCORER=false
# Bearer token that arms the read-only shot-list API for Odysseus preshoot packs.
# MISE_SHOTS_TOKEN=
# Argus vision analyze on gallery publish (one-way POST + inbound gallery index).
# MISE_ARGUS_URL=http://mickey:8010
# MISE_ARGUS_TOKEN=
# MISE_ARGUS_TIMEOUT=30
# MISE_ARGUS_ANALYZE_LIMIT=0
# Phase 2 vision shadow mode: shadow a completed Argus run with a registered challenger
# and record the comparison to ai_runs (never to assets). Off by default; inert until a
# challenger backend is wired in.
# MISE_VISION_SHADOW=false
# Vision challenger backend — Qwen3-VL (32B) on mickeybot via Ollama's OpenAI-compatible
# API. Set URL to a TRUSTED LOCAL endpoint only (never an unapproved cloud vision API).
# Arming this + MISE_VISION_SHADOW makes shadow run for real.
# MISE_VISION_CHALLENGER_URL=http://mickeybot:11434/v1
# MISE_VISION_CHALLENGER_MODEL=qwen3-vl:32b
# MISE_VISION_CHALLENGER_TOKEN=
# MISE_VISION_CHALLENGER_TIMEOUT=120
# MISE_VISION_CHALLENGER_MAX_IMAGES=4
# Validation-scoring harness — the promotion gate over the fixed validation set. MIN_PAIRED
# = items that must be human-scored for BOTH baseline and challenger before parity is judged;
# PARITY_MARGIN = how far the challenger's mean quality must clear the baseline's (0.0 = at
# least parity). The verdict at /admin/validation only REPORTS readiness — promotion stays a
# human action.
# MISE_VALIDATION_MIN_PAIRED=20
# MISE_VALIDATION_PARITY_MARGIN=0.0
# Which provider serves PRODUCTION vision — the cutover switch (default 'argus'). The
# registry interlock honors a provider only if it serves the production contract AND is
# configured, else falls back to Argus. The Qwen challenger is eval-only until it has a
# production writeback path, so 'qwen' is refused (logged) today — promotion is a deliberate
# flip once the validation gate is green AND a production-capable challenger exists.
# MISE_VISION_PROVIDER=argus

# Which provider proposes ALBUM layouts — the album-adopt switch (default 'baseline', the
# deterministic in-app proposer). Same interlock as vision: a Mnemosyne challenger is honored
# only if it serves the production contract AND is configured, else falls back to the baseline.
# 'mnemosyne' is refused (logged) until its layouts beat the baseline and its URL is set.
# MISE_ALBUM_PROVIDER=baseline
# Mnemosyne album-proposer backend — DORMANT until the URL is set. Point ONLY at a trusted LOCAL
# endpoint. Mise POSTs {gallery_id, asset_ids} and reads albums.schema.json placements; the
# deterministic validator still guards every layout.
# MISE_ALBUM_CHALLENGER_URL=http://mickeybot:11500/v1
# MISE_ALBUM_CHALLENGER_MODEL=mnemosyne
# MISE_ALBUM_CHALLENGER_TOKEN=
# MISE_ALBUM_CHALLENGER_TIMEOUT=60

# Plutus print upsell (Phase 1) — queued after Argus callback or on publish when Argus off
# MISE_PLUTUS_URL=http://strix-halo-a9-mega:8030
# MISE_PLUTUS_TOKEN=
# MISE_PLUTUS_TIMEOUT=30
# Phase 3: route offer recommendations through the providers facade + record ai_runs
# provenance. Off by default = legacy plutus path. Offers stay proposal-only either way.
# MISE_PROVIDER_FACADE_OFFERS=false
# Revenue goal bar on the admin home (whole dollars; 0/unset hides it).
# MISE_MONTHLY_GOAL=0
