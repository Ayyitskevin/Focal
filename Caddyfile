# Set MISE_CADDY_SITE_ADDRESS to the platform host and tenant wildcard, for example:
#   mise.example.com, *.mise.example.com
#
# Public wildcard certificates require DNS-challenge support in your Caddy build,
# which the stock caddy image does NOT have. For the hosted deploy use the
# Cloudflare-fronted setup instead (ADR 0059): see Caddyfile.cloudflare and
# docs/SAAS-DEPLOYMENT.md. This default file is fine for single-domain deploys.

{$MISE_CADDY_SITE_ADDRESS} {
	reverse_proxy mise:8400 {
		header_up Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}
