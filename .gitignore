# Secrets — NEVER commit
.env
*.env
!.env.example

# Runtime data: SQLite DBs, client media, zips, tmp, brand uploads (+ owned by mise user)
data/
# Stray SQLite files (e.g. a test/migrate run with the default DB_PATH landing in-repo)
*.db
*.db-wal
*.db-shm

# Local backup snapshots (may contain DB dumps / client PII — never commit)
_bak/
_backups/
backups/

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Editor / OS cruft
*.bak
*.bak.*
*.bak-*
*.swp
.DS_Store
.r/
